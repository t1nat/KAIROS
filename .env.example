# Environment Variables
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────────────
# Authentication (NextAuth.js)
# ─────────────────────────────────────────────────────────────
AUTH_SECRET=your-secret-key-here

# OAuth Providers (optional — enable the ones you need)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_MICROSOFT_ID=
AUTH_MICROSOFT_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL via Supabase)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/kairos

# ─────────────────────────────────────────────────────────────
# File Uploads (UploadThing)
# ─────────────────────────────────────────────────────────────
UPLOADTHING_TOKEN=

# ─────────────────────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL="Kairos <noreply@yourdomain.com>"

# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Google Maps (optional)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────────
# LLM Agent System (HuggingFace Inference API — OpenAI-compatible)
# ─────────────────────────────────────────────────────────────
# Required for AI agents to function
LLM_BASE_URL=https://router.huggingface.co/v1
LLM_API_KEY=hf_your-huggingface-token-here

# Llama 3-tier fallback chain (optional — these are the defaults)
LLM_DEFAULT_MODEL=meta-llama/Llama-3.1-8B-Instruct
LLM_FALLBACK_MODEL=meta-llama/Llama-3.2-3B-Instruct
LLM_ALTERNATE_MODEL=Qwen/Qwen2.5-7B-Instruct

# ─────────────────────────────────────────────────────────────
# Development
# ─────────────────────────────────────────────────────────────
# Set to "1" to skip environment validation during builds
# SKIP_ENV_VALIDATION=1
